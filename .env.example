# PostgreSQL connection string
# Local:  postgresql://localhost:5432/yourmemory
# Docker: postgresql://postgres:postgres@localhost:5432/yourmemory
DATABASE_URL=postgresql://localhost:5432/yourmemory

# Ollama (must be running separately — `ollama serve`)
OLLAMA_URL=http://localhost:11434

# Model used for categorization (fact vs. assumption)
EXTRACT_MODEL=llama3.2:3b
